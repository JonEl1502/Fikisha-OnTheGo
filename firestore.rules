rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // MVP: any signed-in user can browse and update the package board.
    // Tighten before pilot: senders edit own posts, travelers only claim
    // open ones and update status/courier on their own claims.
    match /packages/{packageId} {
      allow read, write: if request.auth != null;
    }
    // ShuleGo (school-run app) shares this Firebase project.
    match /school_runs/{runId} {
      allow read, write: if request.auth != null;
    }
  }
}
